{
  "name": "signalscout",
  "version": "0.1.0",
  "private": true,
  "description": "SignalScout — B2B hiring-signal sales intelligence. An original full-stack SaaS built on Karhuno AI's stack (Next.js, NestJS, Supabase, Gemini).",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm run dev -w frontend",
    "dev:api": "npm run start:dev -w backend",
    "build:shared": "npm run build -w @signalscout/shared",
    "build": "npm run build:shared && npm run build -w backend && npm run build -w frontend",
    "lint": "npm run lint -w backend && npm run lint -w frontend",
    "test": "npm run test -w backend",
    "typecheck": "npm run build:shared && tsc -p backend/tsconfig.json --noEmit",
    "db:start": "npx --yes supabase start",
    "db:stop": "npx --yes supabase stop",
    "db:reset": "npx --yes supabase db reset",
    "db:push": "npx --yes supabase db push",
    "db:seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4"
  }
}
