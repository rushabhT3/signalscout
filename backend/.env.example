# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Supabase (required) ─────────────────────────────────────────────────────
# From your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── AI ──────────────────────────────────────────────────────────────────────
# "mock" runs deterministic fake evaluations (no key, great for local/CI).
# Set "gemini" + a key (free tier: https://aistudio.google.com/apikey) for real output.
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Stripe (test mode) — optional; billing disabled when blank ──────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# ─── Email (Resend) — optional; emails disabled when blank ───────────────────
RESEND_API_KEY=
EMAIL_FROM="SignalScout <onboarding@resend.dev>"

# ─── Background ingestion worker ─────────────────────────────────────────────
INGESTION_ENABLED=false
INGESTION_CRON=0 */6 * * *
INGESTION_BATCH_SIZE=10
